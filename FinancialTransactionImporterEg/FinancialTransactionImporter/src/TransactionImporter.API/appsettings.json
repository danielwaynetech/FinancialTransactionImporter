{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/app/data/transactions.db"
  },
  "CsvSettings": {
    "Delimiter": ",",
    "DateFormat": "yyyy-MM-dd HH:mm:ss",
    "MaxAbsoluteAmount": 9999999.99
  },
  "ApiKey": "dev-api-key-change-me-in-production",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost",
      "http://localhost:80"
    ]
  }
}
